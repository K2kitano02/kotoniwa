<% if object.errors.any? %>
  <div class="error-messages w-full text-red-600 dark:text-red-400 p-4 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-950/50">
    <p class="font-medium"><%= object.errors.count %>件のエラーがあります</p>
    <ul class="list-disc list-inside mt-2 text-sm">
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>